@model IEnumerable<StudentRepositoryDemo.Models.Student>

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center p-4">

            <h1 class="fw-bold mb-0">
                Student List
            </h1>

            <a asp-action="Create"
                   class="btn btn-success btn-lg fw-bold">

                + Add Student

            </a>

        </div>

        <div class="card-body p-4">

            <table class="table table-bordered table-hover text-center align-middle">

                <thead class="table-primary">

                    <tr>

                        <th class="p-3">ID</th>

                        <th class="p-3">Name</th>

                        <th class="p-3">Course</th>

                        <th class="p-3">Age</th>

                        <th class="p-3" width="320">
                            Actions
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="p-3">
                                @item.StudentId
                            </td>

                            <td class="p-3 fw-semibold">
                                @item.Name
                            </td>

                            <td class="p-3">
                                @item.Course
                            </td>

                            <td class="p-3">
                                @item.Age
                            </td>

                            <td class="p-3">

                                <a asp-action="Details"
                                       asp-route-id="@item.StudentId"
                                       class="btn btn-info btn-sm text-white me-2">

                                    Details

                                </a>

                                <a asp-action="Edit"
                                       asp-route-id="@item.StudentId"
                                       class="btn btn-warning btn-sm me-2">

                                    Edit

                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@item.StudentId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Delete this student?')">

                                    Delete

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>